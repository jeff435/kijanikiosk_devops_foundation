# Example Secret structure for kk-payments
# Actual secrets created imperatively - this file is for documentation only
#
# kubectl create secret generic kk-payments-secrets \
#   --from-literal=DB_PASSWORD=<value> \
#   --from-literal=STRIPE_API_KEY=<value> \
#   --from-literal=JWT_SECRET=<value> \
#   -n kijani-project
#
# DO NOT commit actual secret values to Git
apiVersion: v1
kind: Secret
metadata:
  name: kk-payments-secrets
  namespace: kijani-project
type: Opaque
data:
  # These are placeholders - replace with actual base64-encoded values
  DB_PASSWORD: <base64-encoded-password>
  STRIPE_API_KEY: <base64-encoded-key>
  JWT_SECRET: <base64-encoded-secret>
